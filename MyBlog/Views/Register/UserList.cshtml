@model System.Collections.Generic.List<Entities.Concrate.AppUser>
@{
    ViewData["Title"] = "Kullanıcı Listesi";
    Layout = "~/Views/Admin/Index.cshtml";
}

<div class="page-header">
    <div class="page-block">
        <div class="page-header-title">
            <h5 class="mb-0 font-medium">Kullanıcılar</h5>
        </div>
        <ul class="breadcrumb">
            <li class="breadcrumb-item" aria-current="page">Kullanıcı Listesi</li>
        </ul>
    </div>
</div>

<table class="table table-bordered">
    <tr>
        <th>İsim Soyisim</th>
        <th>Kullanıcı Adı</th>
        <th>Email</th>
        <th>Güncelle</th>
        <th>Sil</th>
    </tr>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name @item.Surname</td>
            <td>@item.UserName</td>
            <td>@item.Email</td>
            <td><a href="~/Register/UserUpdate/@item.Id" class="btn btn-outline-dark">Güncelle</a></td>
            <td>
                <form asp-action="UserDelete" asp-controller="Register" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@item.Id" />
                    <button type="submit" class="btn btn-outline-danger"
                            onclick="return confirm('Silmek istediğinize emin misiniz?')">
                        Sil
                    </button>
                </form>
            </td>
        </tr>
    }
</table>
<br/>
<a href="/Register/Index/" class="btn btn-outline-dark">Kullanıcı Ekle</a>
