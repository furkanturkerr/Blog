@model System.Collections.Generic.List<Entities.Concrate.Category>

@{
    ViewData["Title"] = "Kategoriler";
    Layout = "~/Views/Admin/Index.cshtml";
    int s = 0;
}

<div class="page-header">
    <div class="page-block">
        <div class="page-header-title">
            <h5 class="mb-0 font-medium">Kategoriler</h5>
        </div>
        <ul class="breadcrumb">
            <li class="breadcrumb-item" aria-current="page">Kategori Listesi</li>
        </ul>
    </div>
</div>

<table class="table table-bordered">
    <tr>
        <th>#</th>
        <th>Kategori</th>
        <th>Kısa Adı</th>
        <th>Güncelle</th>
        <th>Sil</th>
    </tr>
    @foreach (var item in Model)
    {
        s++;
        <tr>
            <td>@s</td>
            <td>@item.CategoryName</td>
            <td>@item.CategorySlug</td>
            <td><a href="~/Category/EditCategory/@item.CategoryId" class="btn btn-outline-dark">Güncelle</a></td>
            <td>
                <form asp-action="DeleteCategory" asp-controller="Category" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@item.CategoryId" />
                    <button type="submit" class="btn btn-outline-danger"
                            onclick="return confirm('Silmek istediğinize emin misiniz?')">
                        Sil
                    </button>
                </form>
            </td>
        </tr>
    }
</table>

<a href="~/Category/CreateCategory" class="btn btn-outline-dark">Yeni Kategori Ekle</a>